{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex.workflow/schema/tasks.schema.json",
  "title": "Codex Workflow Tasks",
  "type": "object",
  "required": ["version", "project", "workflow", "requests", "tasks"],
  "properties": {
    "version": { "type": "string" },
    "project": {
      "type": "object",
      "required": ["name", "goal", "owner", "updated_at"],
      "properties": {
        "name": { "type": "string" },
        "goal": { "type": "string" },
        "owner": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["mode", "source_of_truth", "default_max_retries", "dispatch_policy"],
      "properties": {
        "mode": { "type": "string" },
        "source_of_truth": { "type": "string" },
        "default_max_retries": { "type": "integer", "minimum": 1 },
        "dispatch_policy": {
          "type": "object",
          "required": ["priority_order", "default_priority", "allow_preemption"],
          "properties": {
            "priority_order": {
              "type": "array",
              "items": { "enum": ["P0", "P1", "P2", "P3"] },
              "minItems": 4,
              "maxItems": 4
            },
            "default_priority": { "enum": ["P0", "P1", "P2", "P3"] },
            "allow_preemption": { "type": "boolean" },
            "default_preempt_lower_priority": { "type": "boolean" },
            "allow_scope_overlap_default": { "type": "boolean" }
          }
        },
        "evidence_schema": { "type": "string" }
      }
    },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "goal", "priority", "status", "created_at"],
        "properties": {
          "id": { "type": "string", "pattern": "^req_[0-9]{3}$" },
          "goal": { "type": "string" },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "status": { "type": "string" },
          "preempt_lower_priority": { "type": "boolean" },
          "preemption_applied": { "type": "boolean" },
          "preempted_tasks": {
            "type": "array",
            "items": { "type": "string", "pattern": "^task_[0-9]{3}$" }
          },
          "created_at": { "type": "string" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "request_id",
          "priority",
          "title",
          "description",
          "phase",
          "owner_role",
          "status",
          "dependencies",
          "scope",
          "acceptance_criteria",
          "retries",
          "max_retries",
          "evidence"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^task_[0-9]{3}$" },
          "request_id": { "type": "string" },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "phase": { "type": "string" },
          "owner_role": { "type": "string" },
          "agent_profile": { "type": "string" },
          "parent_task_id": { "type": "string" },
          "preemptible": { "type": "boolean" },
          "allow_scope_overlap": { "type": "boolean" },
          "status": { "enum": ["todo", "in_progress", "done", "blocked"] },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "pattern": "^task_[0-9]{3}$" }
          },
          "scope": {
            "type": "array",
            "items": { "type": "string" }
          },
          "context_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ac\\.[a-z0-9_.-]+: .+"
            }
          },
          "retries": { "type": "integer", "minimum": 0 },
          "max_retries": { "type": "integer", "minimum": 1 },
          "failure_reason": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updated_at": { "type": "string" }
        }
      }
    }
  }
}
